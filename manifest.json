{
  "manifest_version": 3,
  "name": "Stride - A Reminder to Become Better",
  "version": "1.0.0",
  "description": "Get reminders to take a walk and track your streak.",
  "action": {
    "default_title": "Stride - Become Better",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
